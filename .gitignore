*.py[cod]
*$py.class
*.so

# -----------------------------
# Virtual environments
# -----------------------------
.venv/
venv/
env/
ENV/

# -----------------------------
# Build, packaging, and tooling
# -----------------------------
build/
dist/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/

# -----------------------------
# Test, lint, and type-check caches
# -----------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# -----------------------------
# Jupyter
# -----------------------------
.ipynb_checkpoints/

# -----------------------------
