*.log
logs/

# -----------------------------
# ML artifacts and experiment outputs
# -----------------------------
checkpoints/
models/
outputs/
runs/
wandb/
mlruns/
lightning_logs/

# -----------------------------
# Local data products (keep source code, avoid large/generated data in git)
# -----------------------------
data/*.npy
data/*.npz
data/*.pt
data/*.pth
data/*.ckpt
data/*.bin
data/*.model
data/*.vocab
data/*.tokens
data/*.jsonl
data/*.csv
data/*.txt
data/processed_recipes.txt
data/full_dataset.csv

# Tokenizer artifacts generated by training script
# If you want to version these, remove these two lines.
data/recipe_tokenizer.model
data/recipe_tokenizer.vocab

data/processed_recipes.tokens.npy
data/processed_recipes.tokens.meta.json

# Project planning docs (local)
Transformer_Project_Roadmap.docx
~$*Project_Roadmap.docx

